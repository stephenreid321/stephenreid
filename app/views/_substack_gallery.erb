<% if substack_gallery.present? %>
  <style>
    .substack-notes-gallery .grid-sizer,
    .substack-notes-gallery .grid-item { width: 50%; }
    @media (min-width: 768px) {
      .substack-notes-gallery .grid-sizer,
      .substack-notes-gallery .grid-item { width: 33.333%; }
    }
    @media (min-width: 992px) {
      .substack-notes-gallery .grid-sizer,
      .substack-notes-gallery .grid-item { width: 25%; }
    }
    .substack-notes-gallery .grid-item { padding: 0.35rem; }
    .substack-notes-gallery .grid-item img {
      display: block; width: 100%; height: auto;
      box-shadow: 0 3px 10px rgba(0,0,0,.5), 0 10px 28px rgba(0,0,0,.4),
        0 20px 52px rgba(0,0,0,.32), 0 0 40px rgba(0,0,0,.22);
    }
  </style>
  <div class="row justify-content-center mt-5">
    <div class="col-lg-10">
      <p class="text-contrast text-center">
        Recent images from Substack Notes
      </p>
      <div id="substack-notes-gallery" class="substack-notes-gallery grid" style="opacity: 0">
        <div class="grid-sizer"></div>
        <% substack_gallery.each do |cell| %>
          <div class="grid-item">
            <a href="<%=h cell[:note_url] %>" target="_blank" rel="noopener" class="d-block bg-dark">
              <img src="<%=h cell[:image_url] %>" alt="" onerror="this.closest('.grid-item').style.display='none'">
            </a>
          </div>
        <% end %>
      </div>
      <p class="mt-3 text-center">
        <a target="_blank" rel="noopener" href="https://substack.com/@stephenreid">More on Substack &rarr;</a>
      </p>
    </div>
  </div>
<% end %>
