<p class="lead">
  <a href="/books">
    &larr; All books
  </a>
</p>

<div class="row justify-content-center">
  <div class="col-6 col-lg-3">

    <a target="_blank" href="https://www.goodreads.com/book/show/<%=@book[:book_id]%>">
      <img src="<%= @book[:cover_image] %>" class="w-100 mb-3">
    </a>

  </div>
  <div class="col-lg-9">

    <h2 class="regular mb-3">
      <%=@book[:title]%>
      <br / >
      <small class="text-muted">
        by <%=[@book[:author],@book[:additional_authors]].select { |a| !a.blank? }.to_sentence%></small>
    </h2>

    <div class="blog_post">

      <p>
        <a target="_blank" href="https://www.goodreads.com/book/show/<%=@book[:book_id]%>">
          <i class="bi bi-book"></i> Goodreads
        </a>
      </p>

      <% markdown = Redcarpet::Markdown.new(Redcarpet::Render::HTML.new(hard_wrap: true), autolink: true, tables: true) %>
      <%== markdown.render(@book[:summary].split("\n\n")[1..-1].join("\n\n")) %>
    </div>

  </div>

</div>
