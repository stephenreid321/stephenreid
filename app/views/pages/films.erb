<p class="lead">
  Films I appreciate,
  last updated <%= time_ago_in_words Time.parse(FILMS.map { |f| f[:created_at] }.compact.max) %> ago
</p>

<div class="row">
  <% FILMS.each { |film| %>
  <div class="col-6 col-lg-3 mb-3">
    <%= partial :film, locals: { film: film } %>
  </div>
  <% } %>
</div>
